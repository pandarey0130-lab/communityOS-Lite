{
  "version": "1.0",
  "description": "CommunityOS Multi-Bot Configuration — OpenClaw Agents for Telegram Community Operations",
  "agents": {
    "example_agent": {
      "name": "Example Agent",
      "role": "Community Bot",
      "description": "A helpful community bot.",
      "workspace": "telegram/example",
      "soul": "telegram/example/soul.md",
      "capabilities": [
        "welcome_new_member",
        "scheduled_broadcast",
        "content_recommend"
      ],
      "trigger_conditions": [
        "new_member_joined",
        "scheduled_task",
        "manual_trigger"
      ],
      "persona": {
        "tone": "helpful",
        "style": "friendly",
        "emoji": "🤖"
      }
    }
  },
  "routing": {
    "telegram_bot_token_env": "TELEGRAM_BOT_TOKEN",
    "agent_selector": "message_type",
    "rules": [
      {
        "condition": "new_member_joined",
        "agent": "panda"
      },
      {
        "condition": "mentioned:panda OR panda_username",
        "agent": "panda"
      },
      {
        "condition": "mentioned:cypher OR cypher_username OR tech_keywords",
        "agent": "cypher"
      },
      {
        "condition": "mentioned:buzz OR buzz_username",
        "agent": "buzz"
      },
      {
        "condition": "casual_chat OR no_mention",
        "agent": "buzz"
      },
      {
        "condition": "scheduled_broadcast",
        "agent": "panda"
      }
    ]
  },
  "llm": {
    "provider": "minimax",
    "model": "MiniMax-2.7",
    "temperature": 0.7,
    "max_tokens": 2000
  },
  "shared": {
    "chroma": {
      "persist_directory": "telegram/knowledge/chroma_db",
      "collection_name": "community_knowledge"
    },
    "message_bus": {
      "type": "file",
      "path": "telegram/message_bus.json"
    }
  }
}
