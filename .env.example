# Telegram Bot Tokens (from @BotFather)
TELEGRAM_BOT_TOKEN_PANDA=your_bot_token_here

# LLM API Keys（可选；Lite 在「LLM 配置」里保存的 key 优先于本处）
# 若保留占位符且长度超过 10，旧版会错误覆盖后台已保存的 key；请留空或填真实 key
MINIMAX_API_KEY=
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# Server
HOST=0.0.0.0
PORT=8878
